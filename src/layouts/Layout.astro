---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Tapselo POS — Sistem de vanzare offline pentru magazine",
  description = "POS complet offline cu bon fiscal, cantar Dibal, dashboard AI si instalare de pe USB. Fara Windows, fara licente scumpe.",
} = Astro.props;
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="font-sans text-gray-900 antialiased">
    <slot />
  </body>
</html>
