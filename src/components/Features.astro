---
import {
  WifiOff,
  Printer,
  Scale,
  BrainCircuit,
  Store,
  Monitor,
  KeyRound,
  RefreshCw,
  Database,
  ScanText,
  TrendingUp,
  Terminal,
} from "@lucide/astro";
---

<section id="features" class="bg-white py-24">
  <div class="mx-auto max-w-5xl px-6">
    <h2 class="text-[32px] font-semibold tracking-tight text-neutral-900 sm:text-[40px]">
      Tot ce ai nevoie.<br />
      <span class="text-neutral-300">Nimic in plus.</span>
    </h2>

    <!-- Bento grid -->
    <div class="mt-12 grid gap-3 md:grid-cols-3">
      <!-- Large: Offline -->
      <div class="md:col-span-2 rounded-2xl bg-neutral-900 p-8 text-white">
        <WifiOff class="h-6 w-6 text-primary-400 mb-4" />
        <h3 class="text-[24px] font-semibold">Offline-first</h3>
        <p class="mt-3 max-w-md text-[14px] leading-relaxed text-neutral-400">
          Vinde fara internet. Datele se sincronizeaza automat cand revine conexiunea.
          Zero downtime, zero vanzari pierdute. PGLite local, Electric sync in cloud.
        </p>
      </div>

      <!-- Fiscal -->
      <div class="rounded-2xl ring-1 ring-neutral-100 p-8">
        <Printer class="h-6 w-6 text-neutral-900 mb-4" />
        <h3 class="text-[16px] font-semibold text-neutral-900">Bon fiscal Datecs</h3>
        <p class="mt-2 text-[13px] leading-relaxed text-neutral-500">
          Suport nativ. Conform legislatiei. Plug & play pe USB serial.
        </p>
      </div>

      <!-- Cantar -->
      <div class="rounded-2xl bg-primary-50 ring-1 ring-primary-100 p-8">
        <Scale class="h-6 w-6 text-primary-700 mb-4" />
        <h3 class="text-[16px] font-semibold text-neutral-900">Cantar Dibal</h3>
        <p class="mt-2 text-[13px] leading-relaxed text-neutral-500">
          Cod bare EAN-13, greutate, pret/kg. Totul automat, fara configurari.
        </p>
      </div>

      <!-- Large: Dashboard AI -->
      <div class="md:col-span-2 rounded-2xl bg-primary-600 p-8 text-white">
        <BrainCircuit class="h-6 w-6 text-primary-200 mb-4" />
        <h3 class="text-[24px] font-semibold">Dashboard AI</h3>
        <p class="mt-3 max-w-md text-[14px] leading-relaxed text-primary-100/70">
          Marje, forecast, analiza ABC, matrice profit. Motorul AI genereaza
          recomandari concrete: ce sa promovezi, ce sa scoti, unde pierzi bani.
        </p>
      </div>
    </div>

    <!-- Feature pills -->
    <div class="mt-6 flex flex-wrap gap-2">
      {[
        { name: "Multi-magazin", icon: Store },
        { name: "Ecran client", icon: Monitor },
        { name: "Activare in 6 cifre", icon: KeyRound },
        { name: "Update OTA", icon: RefreshCw },
        { name: "Import MicroERP", icon: Database },
        { name: "Receptie OCR", icon: ScanText },
        { name: "P&L complet", icon: TrendingUp },
        { name: "Terminal Linux", icon: Terminal },
      ].map(({ name, icon: Icon }) => (
        <div class="inline-flex items-center gap-2 rounded-lg ring-1 ring-neutral-200 bg-neutral-50 px-3.5 py-2 text-[13px] font-medium text-neutral-600 transition-colors hover:ring-primary-200 hover:bg-primary-50 hover:text-primary-700">
          <Icon class="h-3.5 w-3.5 text-neutral-400" />
          {name}
        </div>
      ))}
    </div>
  </div>
</section>
