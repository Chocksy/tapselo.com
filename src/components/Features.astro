---
import {
  WifiOff,
  Printer,
  Scale,
  BrainCircuit,
  Store,
  Monitor,
  KeyRound,
  RefreshCw,
  Database,
  ScanText,
  TrendingUp,
  Terminal,
} from "@lucide/astro";
---

<section id="features" class="bg-white py-24">
  <div class="mx-auto max-w-5xl px-6">
    <h2 class="animate-on-scroll text-[24px] font-bold text-neutral-900 sm:text-[32px]">
      Tot ce ai nevoie.<br />
      <span class="text-text-muted">// nimic in plus</span>
    </h2>

    <!-- Bento grid with expressive borders and colors -->
    <div class="mt-12 grid gap-4 md:grid-cols-3">
      <!-- Large: Offline + POS screenshot -->
      <div class="animate-on-scroll md:col-span-2 rounded-md border-2 border-neutral-900 bg-neutral-900 p-0 text-white overflow-hidden group">
        <div class="grid md:grid-cols-2">
          <div class="p-6 md:p-8">
            <WifiOff class="h-6 w-6 text-pink mb-4" />
            <h3 class="text-[18px] font-bold text-white">Offline-first</h3>
            <p class="mt-2 text-[13px] leading-relaxed text-neutral-400">
              Vinde fara internet. Datele se sincronizeaza automat cand revine conexiunea.
              Zero downtime, zero vanzari pierdute.
            </p>
          </div>
          <div class="relative overflow-hidden bg-neutral-800">
            <img src="/screenshots/mockup/pos-cart.jpg" alt="POS — cos cu produse" class="w-full h-full object-cover opacity-80 transition-opacity duration-300 group-hover:opacity-100" loading="lazy" />
          </div>
        </div>
      </div>

      <!-- Fiscal -->
      <div class="animate-on-scroll animate-delay-100 rounded-md border-2 border-neutral-200 p-6 group transition-all duration-200 hover:border-pink hover:-translate-y-1">
        <Printer class="h-5 w-5 text-pink mb-3" />
        <h3 class="text-[16px] font-bold text-neutral-900">Bon fiscal Datecs</h3>
        <p class="mt-2 text-[13px] leading-relaxed text-text-secondary">
          Suport nativ. Conform legislatiei. Plug & play pe USB serial.
        </p>
      </div>

      <!-- Cantar -->
      <div class="animate-on-scroll rounded-md border-2 border-blue bg-blue-light p-6 group transition-all duration-200 hover:-translate-y-1">
        <Scale class="h-5 w-5 text-blue mb-3" />
        <h3 class="text-[16px] font-bold text-neutral-900">Cantar Dibal</h3>
        <p class="mt-2 text-[13px] leading-relaxed text-text-secondary">
          Cod bare EAN-13, greutate, pret/kg. Totul automat, fara configurari.
        </p>
      </div>

      <!-- Large: Dashboard AI + screenshot -->
      <div class="animate-on-scroll animate-delay-100 md:col-span-2 rounded-md border-2 border-pink bg-pink p-0 text-white overflow-hidden group">
        <div class="grid md:grid-cols-2">
          <div class="p-6 md:p-8">
            <BrainCircuit class="h-6 w-6 text-pink-light mb-4" />
            <h3 class="text-[18px] font-bold text-white">Dashboard AI</h3>
            <p class="mt-2 text-[13px] leading-relaxed text-white/70">
              Marje, forecast, analiza ABC, matrice profit. Motorul AI genereaza
              recomandari concrete: ce sa promovezi, ce sa scoti, unde pierzi bani.
            </p>
          </div>
          <div class="relative overflow-hidden bg-pink-dark">
            <img src="/screenshots/mockup/admin-sales-dashboard.jpg" alt="Dashboard — raport vanzari cu AI insights" class="w-full h-full object-cover opacity-80 transition-opacity duration-300 group-hover:opacity-100" loading="lazy" />
          </div>
        </div>
      </div>
    </div>

    <!-- Feature pills — expressive style -->
    <div class="animate-on-scroll mt-8 flex flex-wrap gap-2">
      {[
        { name: "Multi-magazin", icon: Store },
        { name: "Ecran client", icon: Monitor },
        { name: "Activare in 6 cifre", icon: KeyRound },
        { name: "Update OTA", icon: RefreshCw },
        { name: "Import MicroERP", icon: Database },
        { name: "Receptie OCR", icon: ScanText },
        { name: "P&L complet", icon: TrendingUp },
        { name: "Terminal Linux", icon: Terminal },
      ].map(({ name, icon: Icon }) => (
        <div class="inline-flex items-center gap-2 rounded-md border-2 border-neutral-200 bg-white px-3 py-2 text-[12px] font-bold text-neutral-900 transition-all duration-200 hover:border-pink hover:text-pink hover:-translate-y-0.5">
          <Icon class="h-3.5 w-3.5" />
          {name}
        </div>
      ))}
    </div>
  </div>
</section>
