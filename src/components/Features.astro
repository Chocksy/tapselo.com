---
import {
  WifiOff,
  Printer,
  Scale,
  BrainCircuit,
  Store,
  Monitor,
  KeyRound,
  RefreshCw,
  Camera,
  BarChart3,
  Laptop,
  ShieldCheck,
} from "@lucide/astro";
---

<section id="features" class="bg-surface py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="animate-on-scroll font-display text-4xl italic text-primary sm:text-5xl">
      Tot ce ai nevoie.
    </h2>
    <p class="animate-on-scroll animate-delay-100 font-display text-4xl italic text-primary/20 sm:text-5xl">
      Nimic in plus.
    </p>

    <!-- Bento grid -->
    <div class="mt-14 grid gap-4 md:grid-cols-3">
      <!-- Large: Offline -->
      <div class="animate-on-scroll md:col-span-2 rounded-xl bg-primary p-0 text-white relative overflow-hidden group transition-shadow duration-300 hover:shadow-xl hover:shadow-primary/20">
        <div class="grid md:grid-cols-2">
          <div class="p-8 md:p-10">
            <WifiOff class="h-7 w-7 text-accent mb-5 transition-transform duration-300 group-hover:scale-110" />
            <h3 class="text-2xl font-bold text-white">Vinzi si fara internet</h3>
            <p class="mt-3 text-base leading-relaxed text-text-on-primary">
              Pica netul? Nu conteaza. Vinzi in continuare, iar datele se trimit singure
              cand revine conexiunea. Fara pierderi, fara opriri.
            </p>
          </div>
          <div class="relative overflow-hidden rounded-br-xl h-64 md:h-auto min-h-[200px]">
            <img src="/screenshots/mockup/pos-cart-v2.jpg" alt="Ecranul casei de marcat cu produse in cos" class="w-full h-full object-cover opacity-90 transition-all duration-500 group-hover:opacity-100 group-hover:scale-[1.03]" loading="lazy" />
          </div>
        </div>
      </div>

      <!-- Fiscal -->
      <div class="animate-on-scroll animate-delay-100 rounded-xl bg-surface-white p-8 border border-border group transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
        <Printer class="h-6 w-6 text-primary mb-4 transition-transform duration-300 group-hover:scale-110" />
        <h3 class="text-lg font-bold text-primary">Bon fiscal automat</h3>
        <p class="mt-2 text-sm leading-relaxed text-text-secondary">
          Conectezi imprimanta fiscala si gata. Bonul se tipareste la fiecare vanzare, conform legii.
        </p>
      </div>

      <!-- Cantar -->
      <div class="animate-on-scroll rounded-xl bg-cash-light border border-cash/20 p-8 group transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
        <Scale class="h-6 w-6 text-cash mb-4 transition-transform duration-300 group-hover:scale-110" />
        <h3 class="text-lg font-bold text-primary">Cantar integrat</h3>
        <p class="mt-2 text-sm leading-relaxed text-text-secondary">
          Pui produsul pe cantar, pretul apare automat. Fara configurari complicate.
        </p>
      </div>

      <!-- Large: Rapoarte inteligente -->
      <div class="animate-on-scroll animate-delay-100 md:col-span-2 rounded-xl bg-accent p-0 text-white relative overflow-hidden group transition-shadow duration-300 hover:shadow-xl hover:shadow-accent/20">
        <div class="grid md:grid-cols-2">
          <div class="p-8 md:p-10">
            <BrainCircuit class="h-7 w-7 text-white/80 mb-5 transition-transform duration-300 group-hover:scale-110" />
            <h3 class="text-2xl font-bold text-white">Stii exact ce se vinde</h3>
            <p class="mt-3 text-base leading-relaxed text-white/80">
              Rapoarte clare, fara cifre complicate. Vezi ce produse iti aduc profit,
              ce sa promovezi si unde pierzi bani. Cu recomandari automate.
            </p>
          </div>
          <div class="relative overflow-hidden rounded-br-xl h-64 md:h-auto min-h-[200px]">
            <img src="/screenshots/mockup/admin-sales-v2.jpg" alt="Rapoarte de vanzari cu cifre clare" class="w-full h-full object-cover opacity-90 transition-all duration-500 group-hover:opacity-100 group-hover:scale-[1.03]" loading="lazy" />
          </div>
        </div>
      </div>
    </div>

    <!-- Skewed video showcase below features -->
    <div class="animate-on-scroll mt-12" style="perspective: 1200px;">
      <div
        class="mx-auto max-w-4xl overflow-hidden rounded-2xl shadow-2xl shadow-primary/20 border border-border"
        style="transform: rotateX(4deg) rotateY(-2deg); transform-style: preserve-3d;"
      >
        <div class="pointer-events-none absolute inset-0 z-10 bg-gradient-to-br from-white/[0.06] via-transparent to-transparent rounded-2xl"></div>
        <video
          class="w-full"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/screenshots/mockup/admin-dashboard-v2.jpg"
        >
          <source src="/videos/video-features-pos.mp4" type="video/mp4" />
        </video>
      </div>
    </div>

    <!-- Feature pills — store-owner language -->
    <div class="animate-on-scroll mt-8 flex flex-wrap gap-2.5">
      {[
        { name: "Mai multe magazine", icon: Store },
        { name: "Ecran pentru clienti", icon: Monitor },
        { name: "Activare in 2 minute", icon: KeyRound },
        { name: "Se actualizeaza singur", icon: RefreshCw },
        { name: "Import din alt program", icon: Laptop },
        { name: "Scanezi factura cu telefonul", icon: Camera },
        { name: "Rapoarte de profit", icon: BarChart3 },
        { name: "Fara licente scumpe", icon: ShieldCheck },
      ].map(({ name, icon: Icon }) => (
        <div class="inline-flex items-center gap-2 rounded-md border border-border bg-surface-white px-4 py-2.5 text-sm font-medium text-primary transition-all duration-200 hover:border-accent hover:text-accent hover:-translate-y-0.5">
          <Icon class="h-4 w-4" />
          {name}
        </div>
      ))}
    </div>
  </div>
</section>
