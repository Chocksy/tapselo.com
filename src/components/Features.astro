---
import {
  WifiOff,
  Printer,
  Scale,
  BrainCircuit,
  Store,
  Monitor,
  KeyRound,
  RefreshCw,
  Database,
  ScanText,
  TrendingUp,
  Terminal,
} from "@lucide/astro";

const features = [
  {
    name: "Offline-first",
    description:
      "Vinde fara internet. Datele se sincronizeaza automat cand revine conexiunea.",
    icon: WifiOff,
  },
  {
    name: "Bon fiscal Datecs",
    description:
      "Suport nativ pentru imprimantele fiscale Datecs. Bon complet, conform legislatiei.",
    icon: Printer,
  },
  {
    name: "Cantar Dibal integrat",
    description:
      "Citire automata cod bare cantar. Greutate, pret pe kg, totul calculat instant.",
    icon: Scale,
  },
  {
    name: "Dashboard AI",
    description:
      "Insights generate de AI: marje, forecast vanzari, analiza ABC, matrice profit.",
    icon: BrainCircuit,
  },
  {
    name: "Multi-magazin",
    description:
      "Gestioneaza mai multe puncte de vanzare dintr-un singur panou admin.",
    icon: Store,
  },
  {
    name: "Ecran client",
    description:
      "Afiseaza produsele scanate si totalul pe un al doilea monitor, pentru clienti.",
    icon: Monitor,
  },
  {
    name: "Activare in 6 caractere",
    description:
      "Cod de activare scurt, generat din admin. Fara setup complicat.",
    icon: KeyRound,
  },
  {
    name: "Update OTA automat",
    description:
      "Aplicatia se actualizeaza singura. Fara interventie manuala, fara downtime.",
    icon: RefreshCw,
  },
  {
    name: "Import MicroERP",
    description:
      "Migrezi de la MicroERP? Import automat produse, preturi, categorii, furnizori.",
    icon: Database,
  },
  {
    name: "Receptie OCR",
    description:
      "Fotografiezi factura, OCR-ul extrage produsele. Receptia in 5 minute.",
    icon: ScanText,
  },
  {
    name: "P&L complet",
    description:
      "Profit & Loss detaliat: venituri, TVA, cheltuieli, profitabilitate pe produs.",
    icon: TrendingUp,
  },
  {
    name: "Terminal Linux",
    description:
      "Ruleaza pe Linux fara licenta. Orice PC vechi devine terminal POS performant.",
    icon: Terminal,
  },
];
---

<section id="features" class="bg-white py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-16 text-center">
      <h2
        class="text-sm font-semibold tracking-widest text-brand-600 uppercase"
      >
        Functionalitati
      </h2>
      <p class="mt-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
        Tot ce ai nevoie intr-un singur sistem
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-500">
        De la vanzare si bon fiscal pana la AI insights si management
        multi-magazin.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map(({ name, description, icon: Icon }) => (
          <div class="group rounded-2xl border border-gray-100 bg-gray-50/50 p-6 transition-all hover:border-brand-200 hover:bg-brand-50/50 hover:shadow-sm">
            <div class="mb-4 inline-flex rounded-xl bg-brand-100 p-3 text-brand-600 transition-colors group-hover:bg-brand-500 group-hover:text-white">
              <Icon class="h-5 w-5" />
            </div>
            <h3 class="mb-2 text-base font-semibold text-gray-900">{name}</h3>
            <p class="text-sm leading-relaxed text-gray-500">{description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
