---
import { Github } from "@lucide/astro";
---

<footer class="border-t border-neutral-100 bg-white py-10">
  <div class="mx-auto max-w-5xl px-6">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex items-center gap-2">
        <span class="flex h-6 w-6 items-center justify-center rounded-md bg-primary-600 text-[10px] font-bold text-white">T</span>
        <span class="text-[14px] font-semibold text-neutral-900">Tapselo POS</span>
      </div>

      <div class="flex items-center gap-6">
        <a href="#features" class="text-[13px] font-medium text-neutral-400 transition-colors hover:text-neutral-900">Functionalitati</a>
        <a href="#how-it-works" class="text-[13px] font-medium text-neutral-400 transition-colors hover:text-neutral-900">Cum functioneaza</a>
        <a href="#contact" class="text-[13px] font-medium text-neutral-400 transition-colors hover:text-neutral-900">Contact</a>
        <a
          href="https://github.com/Chocksy/tapselo-pos"
          target="_blank"
          rel="noopener noreferrer"
          class="text-neutral-300 transition-colors hover:text-neutral-900"
          aria-label="GitHub repository"
        >
          <Github class="h-4 w-4" />
        </a>
      </div>
    </div>

    <div class="mt-8 border-t border-neutral-100 pt-8 text-center">
      <p class="text-[13px] text-neutral-400">
        &copy; 2026 Tapselo. Toate drepturile rezervate.
      </p>
    </div>
  </div>
</footer>
