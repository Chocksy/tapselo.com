---
import { Github } from "@lucide/astro";
---

<footer class="border-t-2 border-neutral-900 bg-neutral-900 py-10">
  <div class="mx-auto max-w-5xl px-6">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex items-center gap-2">
        <img src="/logo.png" alt="Tapselo" class="h-6 w-6 rounded-md" />
        <span class="text-[13px] font-bold text-white">Tapselo_POS</span>
      </div>

      <div class="flex items-center gap-6">
        <a href="#features" class="text-[12px] font-medium text-neutral-500 transition-colors hover:text-pink"># functionalitati</a>
        <a href="#how-it-works" class="text-[12px] font-medium text-neutral-500 transition-colors hover:text-pink"># cum_functioneaza</a>
        <a href="#contact" class="text-[12px] font-medium text-neutral-500 transition-colors hover:text-pink"># contact</a>
        <a
          href="https://github.com/Chocksy/tapselo-pos"
          target="_blank"
          rel="noopener noreferrer"
          class="text-neutral-600 transition-colors hover:text-pink"
          aria-label="GitHub repository"
        >
          <Github class="h-4 w-4" />
        </a>
      </div>
    </div>

    <div class="mt-8 border-t border-neutral-800 pt-8 text-center">
      <p class="text-[12px] text-neutral-600">
        &copy; 2026 Tapselo. Toate drepturile rezervate.
      </p>
    </div>
  </div>
</footer>
