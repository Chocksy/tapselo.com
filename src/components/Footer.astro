---
import { Github } from "@lucide/astro";
---

<footer class="border-t border-gray-100 bg-white py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex items-center gap-2">
        <span class="flex h-7 w-7 items-center justify-center rounded-md bg-brand-600 text-xs font-black text-white">T</span>
        <span class="font-bold text-gray-900">Tapselo POS</span>
      </div>

      <div class="flex items-center gap-6">
        <a href="#features" class="text-sm text-gray-500 transition-colors duration-150 hover:text-gray-900">Functionalitati</a>
        <a href="#how-it-works" class="text-sm text-gray-500 transition-colors duration-150 hover:text-gray-900">Cum functioneaza</a>
        <a href="#contact" class="text-sm text-gray-500 transition-colors duration-150 hover:text-gray-900">Contact</a>
        <a
          href="https://github.com/Chocksy/tapselo-pos"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 transition-colors duration-150 hover:text-gray-900"
          aria-label="GitHub repository"
        >
          <Github class="h-5 w-5" />
        </a>
      </div>
    </div>

    <div class="mt-8 border-t border-gray-100 pt-8 text-center">
      <p class="text-sm text-gray-400">
        &copy; 2026 Tapselo. Toate drepturile rezervate.
      </p>
    </div>
  </div>
</footer>
