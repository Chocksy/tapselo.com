---
import { Github } from "@lucide/astro";
---

<footer class="bg-primary py-10 border-t border-white/10">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex items-center gap-2">
        <span class="flex h-7 w-7 items-center justify-center rounded bg-accent text-xs font-bold text-white">T</span>
        <span class="text-sm font-bold text-white">Tapselo POS</span>
      </div>

      <div class="flex items-center gap-6">
        <a href="#features" class="text-sm font-medium text-text-on-primary/60 transition-colors hover:text-white">Functionalitati</a>
        <a href="#how-it-works" class="text-sm font-medium text-text-on-primary/60 transition-colors hover:text-white">Cum functioneaza</a>
        <a href="#contact" class="text-sm font-medium text-text-on-primary/60 transition-colors hover:text-white">Contact</a>
        <a
          href="https://github.com/Chocksy/tapselo-pos"
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-on-primary/40 transition-colors hover:text-white"
          aria-label="GitHub repository"
        >
          <Github class="h-4 w-4" />
        </a>
      </div>
    </div>

    <div class="mt-8 border-t border-white/10 pt-8 text-center">
      <p class="text-sm text-text-on-primary/40">
        &copy; 2026 Tapselo. Toate drepturile rezervate.
      </p>
    </div>
  </div>
</footer>
