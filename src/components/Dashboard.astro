---
---

<section id="dashboard" class="bg-gray-50 py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid items-start gap-16 lg:grid-cols-5">
      <!-- Left: Copy — takes 2 cols -->
      <div class="lg:col-span-2">
        <h2 class="text-4xl font-black tracking-tight text-gray-900 sm:text-5xl">
          Date,<br />nu instinct
        </h2>
        <p class="mt-4 text-lg text-gray-500">
          Panoul admin transforma vanzarile in decizii. Cu AI care-ti spune exact ce sa faci.
        </p>

        <div class="mt-10 space-y-8">
          <div>
            <div class="flex items-center gap-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand-600 text-xs font-black text-white">AI</span>
              <h3 class="font-black text-gray-900">Insights automate</h3>
            </div>
            <p class="mt-1 pl-11 text-sm text-gray-500">Ce sa promovezi, ce sa scoti, unde pierzi marja.</p>
          </div>
          <div>
            <div class="flex items-center gap-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-warm-400 text-xs font-black text-white">H</span>
              <h3 class="font-black text-gray-900">Heatmap vanzari</h3>
            </div>
            <p class="mt-1 pl-11 text-sm text-gray-500">Ore de varf, zile aglomerate, tendinte.</p>
          </div>
          <div>
            <div class="flex items-center gap-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-purple-600 text-xs font-black text-white">ABC</span>
              <h3 class="font-black text-gray-900">Analiza ABC</h3>
            </div>
            <p class="mt-1 pl-11 text-sm text-gray-500">Top revenue, mid, low. Focus pe ce conteaza.</p>
          </div>
          <div>
            <div class="flex items-center gap-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-orange-500 text-xs font-black text-white">P&L</span>
              <h3 class="font-black text-gray-900">Matrice profit</h3>
            </div>
            <p class="mt-1 pl-11 text-sm text-gray-500">Volum x marja. Produse star vs produse problema.</p>
          </div>
        </div>
      </div>

      <!-- Right: Dashboard mockup — takes 3 cols -->
      <div class="lg:col-span-3 rounded-3xl bg-gray-900 p-5 md:p-8 shadow-2xl shadow-gray-900/20">
        <!-- KPIs -->
        <div class="grid grid-cols-2 gap-3">
          <div class="rounded-2xl bg-white/[0.06] p-5">
            <div class="text-xs text-gray-500">Vanzari azi</div>
            <div class="mt-1 text-3xl font-black text-white">4,230</div>
            <div class="text-xs text-gray-500">lei</div>
            <div class="mt-2 inline-block rounded-full bg-brand-500/20 px-2 py-0.5 text-xs font-bold text-brand-400">+12%</div>
          </div>
          <div class="rounded-2xl bg-white/[0.06] p-5">
            <div class="text-xs text-gray-500">Tranzactii</div>
            <div class="mt-1 text-3xl font-black text-white">67</div>
            <div class="text-xs text-gray-500">cos mediu 63 lei</div>
          </div>
          <div class="rounded-2xl bg-white/[0.06] p-5">
            <div class="text-xs text-gray-500">Marja bruta</div>
            <div class="mt-1 text-3xl font-black text-white">18.4%</div>
            <div class="mt-2 inline-block rounded-full bg-warm-500/20 px-2 py-0.5 text-xs font-bold text-warm-400">sub target</div>
          </div>
          <div class="rounded-2xl bg-white/[0.06] p-5">
            <div class="text-xs text-gray-500">Produse active</div>
            <div class="mt-1 text-3xl font-black text-white">2,847</div>
            <div class="text-xs text-gray-500">din 3,102</div>
          </div>
        </div>

        <!-- Chart -->
        <div class="mt-4 flex h-32 items-end gap-[3px] rounded-2xl bg-white/[0.04] p-4">
          {[35,55,40,65,50,75,55,85,70,80,90,65,55,75,50,70,85,60,80,95,75,65,85,70,60,50,80,90].map((h, i) => (
            <div
              class="flex-1 rounded-sm transition-all"
              style={`height: ${h}%; background: ${h > 80 ? 'rgb(22 163 74)' : 'rgba(22, 163, 74, 0.3)'}`}
            />
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
