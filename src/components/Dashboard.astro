---
import { BrainCircuit, ChartBar, Grid3x3, TrendingUp } from "@lucide/astro";

const capabilities = [
  {
    title: "AI Insights",
    description:
      "Motorul AI analizeaza vanzarile si genereaza recomandari: ce produse sa promovezi, ce sa scoti din stoc, unde pierzi marja.",
    icon: BrainCircuit,
  },
  {
    title: "Heatmap vanzari",
    description:
      "Vizualizeaza orele de varf, zilele aglomerate si tendintele sezoniere pe o harta termica interactiva.",
    icon: ChartBar,
  },
  {
    title: "Analiza ABC",
    description:
      "Clasifica automat produsele in A (top revenue), B (mid) si C (low). Focuseaza-te pe ce conteaza.",
    icon: Grid3x3,
  },
  {
    title: "Matrice profit",
    description:
      "Incruciseaza volumul de vanzari cu marja de profit. Identifica instant produsele star si pe cele care te trag in jos.",
    icon: TrendingUp,
  },
];
---

<section id="dashboard" class="bg-white py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-16 text-center">
      <h2
        class="text-sm font-semibold tracking-widest text-brand-600 uppercase"
      >
        Dashboard Admin
      </h2>
      <p class="mt-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
        Date, nu instinct
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-500">
        Panoul admin iti arata exact ce se intampla in magazin. Cu AI care
        transforma datele in decizii.
      </p>
    </div>

    <!-- Dashboard mockup card -->
    <div class="relative mx-auto max-w-4xl overflow-hidden rounded-3xl border border-gray-200 bg-gradient-to-br from-gray-900 to-gray-800 p-1">
      <div class="rounded-[20px] bg-gray-900 p-6 md:p-10">
        <!-- Fake browser chrome -->
        <div class="mb-6 flex items-center gap-2">
          <div class="h-3 w-3 rounded-full bg-red-500/60"></div>
          <div class="h-3 w-3 rounded-full bg-yellow-500/60"></div>
          <div class="h-3 w-3 rounded-full bg-green-500/60"></div>
          <div class="ml-4 h-6 flex-1 rounded-md bg-white/5"></div>
        </div>

        <!-- Dashboard content representation -->
        <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
          <div class="rounded-xl bg-white/5 p-4">
            <div class="mb-2 text-xs text-gray-500">Vanzari azi</div>
            <div class="text-xl font-bold text-white">4,230 lei</div>
            <div class="mt-1 text-xs text-brand-400">+12% vs ieri</div>
          </div>
          <div class="rounded-xl bg-white/5 p-4">
            <div class="mb-2 text-xs text-gray-500">Tranzactii</div>
            <div class="text-xl font-bold text-white">67</div>
            <div class="mt-1 text-xs text-brand-400">cos mediu: 63 lei</div>
          </div>
          <div class="rounded-xl bg-white/5 p-4">
            <div class="mb-2 text-xs text-gray-500">Marja bruta</div>
            <div class="text-xl font-bold text-white">18.4%</div>
            <div class="mt-1 text-xs text-yellow-400">sub target 20%</div>
          </div>
          <div class="rounded-xl bg-white/5 p-4">
            <div class="mb-2 text-xs text-gray-500">Produse active</div>
            <div class="text-xl font-bold text-white">2,847</div>
            <div class="mt-1 text-xs text-gray-500">din 3,102 total</div>
          </div>
        </div>

        <!-- Fake chart area -->
        <div class="mt-6 flex h-32 items-end gap-1 rounded-xl bg-white/5 p-4">
          {
            [40, 65, 45, 70, 55, 80, 60, 90, 75, 85, 95, 70, 60, 80, 55, 75, 90, 65, 85, 100, 80, 70, 90, 75].map(
              (h) => (
                <div
                  class="flex-1 rounded-t bg-brand-500/60"
                  style={`height: ${h}%`}
                />
              ),
            )
          }
        </div>
      </div>
    </div>

    <!-- Capabilities grid below -->
    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        capabilities.map(({ title, description, icon: Icon }) => (
          <div class="text-center">
            <div class="mx-auto mb-4 inline-flex rounded-xl bg-gray-100 p-3 text-gray-700">
              <Icon class="h-6 w-6" />
            </div>
            <h3 class="mb-2 text-base font-semibold text-gray-900">{title}</h3>
            <p class="text-sm leading-relaxed text-gray-500">{description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
