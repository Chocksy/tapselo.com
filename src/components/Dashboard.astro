---
---

<section id="dashboard" class="bg-primary py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid items-start gap-16 lg:grid-cols-5">
      <!-- Left: Copy -->
      <div class="lg:col-span-2">
        <h2 class="animate-on-scroll font-display text-4xl font-bold uppercase tracking-wide text-white sm:text-5xl">
          Date,<br />nu instinct
        </h2>
        <p class="animate-on-scroll animate-delay-100 mt-4 text-lg leading-relaxed text-text-on-primary">
          Panoul admin transforma vanzarile in decizii. Cu AI care-ti spune exact ce sa faci.
        </p>

        <div class="mt-10 space-y-7">
          <div class="animate-on-scroll">
            <div class="flex items-center gap-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-accent text-xs font-bold text-white">AI</span>
              <h3 class="font-bold text-white">Insights automate</h3>
            </div>
            <p class="mt-1 pl-11 text-sm text-text-on-primary/70">Ce sa promovezi, ce sa scoti, unde pierzi marja.</p>
          </div>
          <div class="animate-on-scroll animate-delay-100">
            <div class="flex items-center gap-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-warning text-xs font-bold text-white">H</span>
              <h3 class="font-bold text-white">Heatmap vanzari</h3>
            </div>
            <p class="mt-1 pl-11 text-sm text-text-on-primary/70">Ore de varf, zile aglomerate, tendinte.</p>
          </div>
          <div class="animate-on-scroll animate-delay-200">
            <div class="flex items-center gap-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-primary-muted text-xs font-bold text-white">ABC</span>
              <h3 class="font-bold text-white">Analiza ABC</h3>
            </div>
            <p class="mt-1 pl-11 text-sm text-text-on-primary/70">Top revenue, mid, low. Focus pe ce conteaza.</p>
          </div>
          <div class="animate-on-scroll animate-delay-300">
            <div class="flex items-center gap-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-danger text-xs font-bold text-white">P&L</span>
              <h3 class="font-bold text-white">Matrice profit</h3>
            </div>
            <p class="mt-1 pl-11 text-sm text-text-on-primary/70">Volum x marja. Produse star vs produse problema.</p>
          </div>
        </div>
      </div>

      <!-- Right: Mockup screenshots -->
      <div class="animate-on-scroll animate-from-right lg:col-span-3 space-y-6">
        <div class="group transition-transform duration-500 hover:-translate-y-1">
          <img src="/screenshots/mockup/admin-sales-v2.jpg" alt="Dashboard — KPI cards cu venituri, tranzactii si marja" class="w-full rounded-lg" loading="lazy" />
        </div>
        <div class="group transition-transform duration-500 hover:-translate-y-1">
          <img src="/screenshots/mockup/admin-devices-v2.jpg" alt="Admin — monitorizare terminale POS cu status" class="w-full rounded-lg" loading="lazy" />
        </div>
      </div>
    </div>
  </div>
</section>
