---
---

<section id="dashboard" class="bg-neutral-900 py-24 border-y-2 border-neutral-900">
  <div class="mx-auto max-w-5xl px-6">
    <div class="grid items-start gap-16 lg:grid-cols-5">
      <!-- Left: Copy -->
      <div class="lg:col-span-2">
        <h2 class="animate-on-scroll text-[24px] font-bold text-white sm:text-[32px]">
          Date,<br /><span class="text-pink">nu instinct</span>
        </h2>
        <p class="animate-on-scroll animate-delay-100 mt-4 text-[14px] leading-relaxed text-neutral-400">
          Panoul admin transforma vanzarile in decizii. Cu AI care-ti spune exact ce sa faci.
        </p>

        <div class="mt-8 space-y-6">
          <div class="animate-on-scroll">
            <div class="flex items-center gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-pink text-[10px] font-bold text-white">AI</span>
              <h3 class="text-[14px] font-bold text-white">Insights automate</h3>
            </div>
            <p class="mt-1 pl-10 text-[12px] text-neutral-500">Ce sa promovezi, ce sa scoti, unde pierzi marja.</p>
          </div>
          <div class="animate-on-scroll animate-delay-100">
            <div class="flex items-center gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-warning text-[10px] font-bold text-white">H</span>
              <h3 class="text-[14px] font-bold text-white">Heatmap vanzari</h3>
            </div>
            <p class="mt-1 pl-10 text-[12px] text-neutral-500">Ore de varf, zile aglomerate, tendinte.</p>
          </div>
          <div class="animate-on-scroll animate-delay-200">
            <div class="flex items-center gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-blue text-[10px] font-bold text-white">ABC</span>
              <h3 class="text-[14px] font-bold text-white">Analiza ABC</h3>
            </div>
            <p class="mt-1 pl-10 text-[12px] text-neutral-500">Top revenue, mid, low. Focus pe ce conteaza.</p>
          </div>
          <div class="animate-on-scroll animate-delay-300">
            <div class="flex items-center gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-danger text-[10px] font-bold text-white">P&L</span>
              <h3 class="text-[14px] font-bold text-white">Matrice profit</h3>
            </div>
            <p class="mt-1 pl-10 text-[12px] text-neutral-500">Volum x marja. Produse star vs produse problema.</p>
          </div>
        </div>
      </div>

      <!-- Right: Mockup screenshots -->
      <div class="animate-on-scroll animate-from-right lg:col-span-3 space-y-4">
        <div class="rounded-md border-2 border-white/10 bg-white/5 p-3 transition-transform duration-300 hover:-translate-y-1">
          <img src="/screenshots/mockup/admin-sales-dashboard.jpg" alt="Dashboard — raport vanzari" class="w-full rounded-sm" loading="lazy" />
        </div>
        <div class="rounded-md border-2 border-white/10 bg-white/5 p-3 transition-transform duration-300 hover:-translate-y-1">
          <img src="/screenshots/mockup/admin-devices.jpg" alt="Admin — monitorizare terminale" class="w-full rounded-sm" loading="lazy" />
        </div>
      </div>
    </div>
  </div>
</section>
