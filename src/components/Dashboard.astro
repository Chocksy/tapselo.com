---
---

<section id="dashboard" class="bg-neutral-50 py-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="grid items-start gap-16 lg:grid-cols-5">
      <!-- Left: Copy -->
      <div class="lg:col-span-2">
        <h2 class="text-[32px] font-semibold tracking-tight text-neutral-900 sm:text-[40px]">
          Date,<br />nu instinct
        </h2>
        <p class="mt-4 text-[16px] leading-relaxed text-neutral-500">
          Panoul admin transforma vanzarile in decizii. Cu AI care-ti spune exact ce sa faci.
        </p>

        <div class="mt-8 space-y-6">
          <div>
            <div class="flex items-center gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-primary-600 text-[11px] font-bold text-white">AI</span>
              <h3 class="text-[14px] font-semibold text-neutral-900">Insights automate</h3>
            </div>
            <p class="mt-1 pl-10 text-[13px] text-neutral-500">Ce sa promovezi, ce sa scoti, unde pierzi marja.</p>
          </div>
          <div>
            <div class="flex items-center gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-warm-400 text-[11px] font-bold text-white">H</span>
              <h3 class="text-[14px] font-semibold text-neutral-900">Heatmap vanzari</h3>
            </div>
            <p class="mt-1 pl-10 text-[13px] text-neutral-500">Ore de varf, zile aglomerate, tendinte.</p>
          </div>
          <div>
            <div class="flex items-center gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-secondary-500 text-[11px] font-bold text-white">ABC</span>
              <h3 class="text-[14px] font-semibold text-neutral-900">Analiza ABC</h3>
            </div>
            <p class="mt-1 pl-10 text-[13px] text-neutral-500">Top revenue, mid, low. Focus pe ce conteaza.</p>
          </div>
          <div>
            <div class="flex items-center gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-warning-500 text-[11px] font-bold text-white">P&L</span>
              <h3 class="text-[14px] font-semibold text-neutral-900">Matrice profit</h3>
            </div>
            <p class="mt-1 pl-10 text-[13px] text-neutral-500">Volum x marja. Produse star vs produse problema.</p>
          </div>
        </div>
      </div>

      <!-- Right: Dashboard mockup -->
      <div class="lg:col-span-3 rounded-2xl bg-neutral-900 p-4 md:p-6 shadow-2xl shadow-neutral-900/10">
        <!-- KPIs -->
        <div class="grid grid-cols-2 gap-3">
          <div class="rounded-xl bg-white/[0.06] p-4">
            <div class="text-[12px] text-neutral-500">Vanzari azi</div>
            <div class="mt-1 text-[28px] font-semibold leading-none text-white">4,230</div>
            <div class="text-[11px] text-neutral-500 mt-0.5">lei</div>
            <div class="mt-2 inline-block rounded-md bg-primary-500/20 px-2 py-0.5 text-[11px] font-semibold text-primary-400">+12%</div>
          </div>
          <div class="rounded-xl bg-white/[0.06] p-4">
            <div class="text-[12px] text-neutral-500">Tranzactii</div>
            <div class="mt-1 text-[28px] font-semibold leading-none text-white">67</div>
            <div class="text-[11px] text-neutral-500 mt-0.5">cos mediu 63 lei</div>
          </div>
          <div class="rounded-xl bg-white/[0.06] p-4">
            <div class="text-[12px] text-neutral-500">Marja bruta</div>
            <div class="mt-1 text-[28px] font-semibold leading-none text-white">18.4%</div>
            <div class="mt-2 inline-block rounded-md bg-warm-500/20 px-2 py-0.5 text-[11px] font-semibold text-warm-400">sub target</div>
          </div>
          <div class="rounded-xl bg-white/[0.06] p-4">
            <div class="text-[12px] text-neutral-500">Produse active</div>
            <div class="mt-1 text-[28px] font-semibold leading-none text-white">2,847</div>
            <div class="text-[11px] text-neutral-500 mt-0.5">din 3,102</div>
          </div>
        </div>

        <!-- Mini chart -->
        <div class="mt-3 flex h-28 items-end gap-[3px] rounded-xl bg-white/[0.03] p-3">
          {[35,55,40,65,50,75,55,85,70,80,90,65,55,75,50,70,85,60,80,95,75,65,85,70,60,50,80,90].map((h) => (
            <div
              class="flex-1 rounded-sm transition-all"
              style={`height: ${h}%; background: ${h > 80 ? 'rgb(22 163 74)' : 'rgba(22, 163, 74, 0.25)'}`}
            />
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
