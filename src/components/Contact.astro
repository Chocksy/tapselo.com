---
import { Mail, Phone, Clock } from "@lucide/astro";
---

<section id="contact" class="bg-surface-white py-24 border-t border-border">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid gap-16 lg:grid-cols-2">
      <!-- Left -->
      <div>
        <h2 class="animate-on-scroll font-display text-4xl italic text-primary sm:text-5xl">
          Hai sa vorbim
        </h2>
        <p class="animate-on-scroll animate-delay-100 mt-4 text-lg leading-relaxed text-text-secondary">
          Spune-ne despre magazinul tau si iti aratam cum functioneaza.
          Gratuit, fara obligatii.
        </p>

        <div class="mt-10 space-y-6">
          <div class="animate-on-scroll flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary-subtle text-primary transition-transform duration-300 hover:scale-110">
              <Clock class="h-5 w-5" />
            </div>
            <div>
              <h4 class="font-bold text-primary">Raspuns rapid</h4>
              <p class="text-sm text-text-secondary">Raspundem in 24 de ore</p>
            </div>
          </div>
          <div class="animate-on-scroll animate-delay-100 flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary-subtle text-primary transition-transform duration-300 hover:scale-110">
              <Mail class="h-5 w-5" />
            </div>
            <div>
              <h4 class="font-bold text-primary">Email</h4>
              <p class="text-sm text-text-secondary">contact@tapselo.com</p>
            </div>
          </div>
          <div class="animate-on-scroll animate-delay-200 flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary-subtle text-primary transition-transform duration-300 hover:scale-110">
              <Phone class="h-5 w-5" />
            </div>
            <div>
              <h4 class="font-bold text-primary">Telefon</h4>
              <p class="text-sm text-text-secondary">Disponibil dupa programare</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="animate-on-scroll animate-from-right">
        <form
          id="contact-form"
          class="space-y-5 rounded-xl border border-border bg-surface p-6 md:p-8"
        >
          <div>
            <label for="name" class="mb-1.5 block text-sm font-bold text-primary">Nume complet</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="w-full rounded-md border border-border bg-surface-white px-4 py-3 text-sm text-text transition-all placeholder:text-text-muted focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none"
              placeholder="Ion Popescu"
            />
          </div>
          <div>
            <label for="email" class="mb-1.5 block text-sm font-bold text-primary">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full rounded-md border border-border bg-surface-white px-4 py-3 text-sm text-text transition-all placeholder:text-text-muted focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none"
              placeholder="ion@magazin.ro"
            />
          </div>
          <div>
            <label for="phone" class="mb-1.5 block text-sm font-bold text-primary">Telefon</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              autocomplete="tel"
              class="w-full rounded-md border border-border bg-surface-white px-4 py-3 text-sm text-text transition-all placeholder:text-text-muted focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none"
              placeholder="07XX XXX XXX"
            />
          </div>
          <div>
            <label for="message" class="mb-1.5 block text-sm font-bold text-primary">Mesaj</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full resize-none rounded-md border border-border bg-surface-white px-4 py-3 text-sm text-text transition-all placeholder:text-text-muted focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none"
              placeholder="Cate terminale ai nevoie, ce imprimanta fiscala folosesti, etc."
            ></textarea>
          </div>

          <!-- Cloudflare Turnstile -->
          <div class="cf-turnstile" data-sitekey="0x4AAAAAACtT6gLbdqQrMEwT" data-theme="light"></div>

          <div id="form-status" class="hidden rounded-md p-3 text-sm font-medium"></div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full rounded-md bg-accent py-3.5 text-base font-bold text-white transition-all hover:bg-accent-hover hover:shadow-lg hover:shadow-accent/25 active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Trimite mesajul
          </button>
          <p class="text-center text-xs text-text-muted">
            Protejat de Cloudflare. Datele tale sunt in siguranta.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
