---
---

<section id="how-it-works" class="bg-surface-white py-24 border-y border-border">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="animate-on-scroll font-display text-4xl font-bold uppercase tracking-wide text-primary sm:text-5xl">
      20 de minute.
    </h2>
    <p class="animate-on-scroll animate-delay-100 mt-1 font-display text-4xl font-bold uppercase tracking-wide text-primary/20 sm:text-5xl">
      De la cutie la prima vanzare.
    </p>

    <div class="mt-16 grid gap-12 md:grid-cols-3 md:gap-8">
      <div class="animate-on-scroll relative">
        <div class="font-display text-[80px] font-bold leading-none text-accent/15 md:text-[100px]" aria-hidden="true">1</div>
        <div class="mt-[-16px] relative">
          <h3 class="text-xl font-bold text-primary">Instalezi de pe USB</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Stick USB bootabil. Pornesti PC-ul, astepti 15 minute. Linux + Tapselo, gata. Orice PC vechi merge.
          </p>
        </div>
      </div>
      <div class="animate-on-scroll animate-delay-100 relative">
        <div class="font-display text-[80px] font-bold leading-none text-accent/15 md:text-[100px]" aria-hidden="true">2</div>
        <div class="mt-[-16px] relative">
          <h3 class="text-xl font-bold text-primary">Activezi cu un cod</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            6 caractere din panoul admin. Il tastezi pe terminal, dispozitivul e activ. Fara tehnicieni.
          </p>
        </div>
      </div>
      <div class="animate-on-scroll animate-delay-200 relative">
        <div class="font-display text-[80px] font-bold leading-none text-accent/15 md:text-[100px]" aria-hidden="true">3</div>
        <div class="mt-[-16px] relative">
          <h3 class="text-xl font-bold text-primary">Vinzi</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Scanezi, incasezi, tiparesti bon fiscal. Cu sau fara internet — sync automat in cloud.
          </p>
        </div>
      </div>
    </div>

    <!-- Product screenshots — 3-up mockup grid -->
    <div class="mt-16 grid gap-6 md:grid-cols-3">
      <div class="animate-on-scroll group">
        <img src="/screenshots/mockup/pos-cart-v2.jpg" alt="POS — Interfata de vanzare cu produse in cos" class="w-full rounded-lg transition-transform duration-500 group-hover:-translate-y-2" loading="lazy" />
        <p class="mt-3 text-center text-sm font-bold text-primary">POS Terminal</p>
        <p class="text-center text-xs text-text-secondary">Scanezi, adaugi in cos, finalizezi</p>
      </div>
      <div class="animate-on-scroll animate-delay-100 group">
        <img src="/screenshots/mockup/admin-dashboard-v2.jpg" alt="Admin — Panou de control cu module" class="w-full rounded-lg transition-transform duration-500 group-hover:-translate-y-2" loading="lazy" />
        <p class="mt-3 text-center text-sm font-bold text-primary">Admin Dashboard</p>
        <p class="text-center text-xs text-text-secondary">Gestionezi totul dintr-un singur loc</p>
      </div>
      <div class="animate-on-scroll animate-delay-200 group">
        <img src="/screenshots/mockup/admin-receptie-v2.jpg" alt="Admin — Receptie marfa cu OCR scanare factura" class="w-full rounded-lg transition-transform duration-500 group-hover:-translate-y-2" loading="lazy" />
        <p class="mt-3 text-center text-sm font-bold text-primary">Receptie OCR</p>
        <p class="text-center text-xs text-text-secondary">Fotografiezi factura, se completeaza singura</p>
      </div>
    </div>
  </div>
</section>
