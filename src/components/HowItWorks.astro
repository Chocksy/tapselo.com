---
---

<section id="how-it-works" class="bg-neutral-50 py-24 border-y-2 border-neutral-200">
  <div class="mx-auto max-w-5xl px-6">
    <h2 class="animate-on-scroll text-[24px] font-bold text-neutral-900 sm:text-[32px]">
      20 de minute.
    </h2>
    <p class="animate-on-scroll animate-delay-100 mt-1 text-[24px] font-bold text-text-muted sm:text-[32px]">
      // de la cutie la prima vanzare
    </p>

    <div class="mt-16 grid gap-12 md:grid-cols-3 md:gap-8">
      <div class="animate-on-scroll relative">
        <div class="text-[64px] font-bold leading-none text-pink/10 md:text-[80px]" aria-hidden="true">01</div>
        <div class="mt-[-12px] relative">
          <h3 class="text-[16px] font-bold text-neutral-900">Instalezi de pe USB</h3>
          <p class="mt-2 text-[13px] leading-relaxed text-text-secondary">
            Stick USB bootabil. Pornesti PC-ul, astepti 15 minute. Linux + Tapselo, gata. Orice PC vechi merge.
          </p>
        </div>
      </div>
      <div class="animate-on-scroll animate-delay-100 relative">
        <div class="text-[64px] font-bold leading-none text-blue/10 md:text-[80px]" aria-hidden="true">02</div>
        <div class="mt-[-12px] relative">
          <h3 class="text-[16px] font-bold text-neutral-900">Activezi cu un cod</h3>
          <p class="mt-2 text-[13px] leading-relaxed text-text-secondary">
            6 caractere din panoul admin. Il tastezi pe terminal, dispozitivul e activ. Fara tehnicieni.
          </p>
        </div>
      </div>
      <div class="animate-on-scroll animate-delay-200 relative">
        <div class="text-[64px] font-bold leading-none text-success/10 md:text-[80px]" aria-hidden="true">03</div>
        <div class="mt-[-12px] relative">
          <h3 class="text-[16px] font-bold text-neutral-900">Vinzi</h3>
          <p class="mt-2 text-[13px] leading-relaxed text-text-secondary">
            Scanezi, incasezi, tiparesti bon fiscal. Cu sau fara internet — sync automat in cloud.
          </p>
        </div>
      </div>
    </div>

    <!-- Product mockup screenshots — 3-up -->
    <div class="mt-16 grid gap-6 md:grid-cols-3">
      <div class="animate-on-scroll group">
        <div class="rounded-md border-2 border-neutral-200 bg-white p-3 transition-all duration-300 group-hover:border-pink group-hover:-translate-y-2">
          <img src="/screenshots/mockup/pos-cart.jpg" alt="POS — Interfata de vanzare" class="w-full rounded-sm" loading="lazy" />
        </div>
        <p class="mt-3 text-[12px] font-bold text-pink">// pos_terminal</p>
        <p class="text-[11px] text-text-secondary">Scanezi, adaugi in cos, finalizezi</p>
      </div>
      <div class="animate-on-scroll animate-delay-100 group">
        <div class="rounded-md border-2 border-neutral-200 bg-white p-3 transition-all duration-300 group-hover:border-blue group-hover:-translate-y-2">
          <img src="/screenshots/mockup/admin-dashboard.jpg" alt="Admin — Panou de control" class="w-full rounded-sm" loading="lazy" />
        </div>
        <p class="mt-3 text-[12px] font-bold text-blue">// admin_dashboard</p>
        <p class="text-[11px] text-text-secondary">Gestionezi totul dintr-un singur loc</p>
      </div>
      <div class="animate-on-scroll animate-delay-200 group">
        <div class="rounded-md border-2 border-neutral-200 bg-white p-3 transition-all duration-300 group-hover:border-success group-hover:-translate-y-2">
          <img src="/screenshots/mockup/admin-receptie-ocr.jpg" alt="Admin — Receptie OCR" class="w-full rounded-sm" loading="lazy" />
        </div>
        <p class="mt-3 text-[12px] font-bold text-success">// receptie_ocr</p>
        <p class="text-[11px] text-text-secondary">Fotografiezi factura, se completeaza singura</p>
      </div>
    </div>
  </div>
</section>
