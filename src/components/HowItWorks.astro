---
---

<section id="how-it-works" class="bg-surface-white py-24 border-y border-border">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="animate-on-scroll font-display text-4xl italic text-primary sm:text-5xl">
      20 de minute.
    </h2>
    <p class="animate-on-scroll animate-delay-100 mt-1 font-display text-4xl italic text-primary/20 sm:text-5xl">
      De la cutie la prima vanzare.
    </p>

    <div class="mt-16 grid gap-12 md:grid-cols-3 md:gap-8">
      <div class="animate-on-scroll relative">
        <div class="font-display text-[80px] italic leading-none text-accent/15 md:text-[100px]" aria-hidden="true">1</div>
        <div class="mt-[-16px] relative">
          <h3 class="text-xl font-bold text-primary">Pornesti de pe stick</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Pui un stick USB in orice calculator. Astepti 20 de minute. Gata — ai casa de marcat functionala. Merge si pe un PC mai vechi.
          </p>
        </div>
      </div>
      <div class="animate-on-scroll animate-delay-100 relative">
        <div class="font-display text-[80px] italic leading-none text-accent/15 md:text-[100px]" aria-hidden="true">2</div>
        <div class="mt-[-16px] relative">
          <h3 class="text-xl font-bold text-primary">Tastezi un cod scurt</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            6 caractere pe care le generezi din panoul de administrare. Le tastezi pe ecran si casa e activa. Fara tehnicieni.
          </p>
        </div>
      </div>
      <div class="animate-on-scroll animate-delay-200 relative">
        <div class="font-display text-[80px] italic leading-none text-accent/15 md:text-[100px]" aria-hidden="true">3</div>
        <div class="mt-[-16px] relative">
          <h3 class="text-xl font-bold text-primary">Incepi sa vinzi</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Scanezi produsele, incasezi, tiparesti bonul fiscal. Cu sau fara internet — totul se salveaza automat.
          </p>
        </div>
      </div>
    </div>

    <!-- Product screenshots -->
    <div class="mt-16 grid gap-6 md:grid-cols-3">
      <div class="animate-on-scroll group">
        <img src="/screenshots/mockup/pos-cart-v2.jpg" alt="Ecranul casei de marcat" class="w-full rounded-lg transition-transform duration-500 group-hover:-translate-y-2" loading="lazy" />
        <p class="mt-3 text-center text-sm font-bold text-primary">Casa de marcat</p>
        <p class="text-center text-xs text-text-secondary">Scanezi, adaugi in cos, incasezi</p>
      </div>
      <div class="animate-on-scroll animate-delay-100 group">
        <img src="/screenshots/mockup/admin-dashboard-v2.jpg" alt="Panoul de administrare" class="w-full rounded-lg transition-transform duration-500 group-hover:-translate-y-2" loading="lazy" />
        <p class="mt-3 text-center text-sm font-bold text-primary">Panoul de administrare</p>
        <p class="text-center text-xs text-text-secondary">Totul intr-un singur loc</p>
      </div>
      <div class="animate-on-scroll animate-delay-200 group">
        <img src="/screenshots/mockup/admin-receptie-v2.jpg" alt="Receptie marfa cu scanare factura" class="w-full rounded-lg transition-transform duration-500 group-hover:-translate-y-2" loading="lazy" />
        <p class="mt-3 text-center text-sm font-bold text-primary">Receptie marfa</p>
        <p class="text-center text-xs text-text-secondary">Fotografiezi factura, se completeaza singura</p>
      </div>
    </div>
  </div>
</section>
