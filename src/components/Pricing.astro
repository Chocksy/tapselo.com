---
import { Check, ArrowRight } from "@lucide/astro";

const included = [
  "Casa de marcat care merge si fara internet",
  "Rapoarte de vanzari cu recomandari automate",
  "Bon fiscal — conectezi imprimanta si gata",
  "Cantar integrat — pretul apare automat",
  "Mai multe magazine dintr-un singur cont",
  "Se actualizeaza singur, fara opriri",
  "Import produse din programul vechi",
  "Suport tehnic prin email",
];
---

<section id="pricing" class="bg-surface py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <!-- Left -->
      <div>
        <h2 class="animate-on-scroll font-display text-4xl italic text-primary sm:text-5xl">
          Simplu.<br />
          Transparent.<br />
          <span class="text-accent">Fara surprize.</span>
        </h2>
        <p class="animate-on-scroll animate-delay-100 mt-5 text-lg leading-relaxed text-text-secondary">
          Fiecare magazin e diferit. Spune-ne cate case de marcat ai nevoie si iti facem o oferta pe masura.
        </p>
        <div class="animate-on-scroll animate-delay-200 mt-8 rounded-xl bg-cash-light border border-cash/20 p-6 transition-shadow duration-300 hover:shadow-lg">
          <p class="font-display text-3xl italic text-cash">~600 lei economie</p>
          <p class="mt-1 text-sm text-text-secondary">la fiecare casa de marcat, fara licente scumpe</p>
        </div>
      </div>

      <!-- Right: Included -->
      <div class="animate-on-scroll animate-from-right rounded-xl bg-surface-white border border-border p-8 md:p-10 transition-shadow duration-300 hover:shadow-xl">
        <h3 class="text-lg font-bold text-primary">Include:</h3>
        <ul class="mt-6 space-y-4">
          {included.map((item) => (
            <li class="flex items-start gap-3">
              <Check class="mt-0.5 h-5 w-5 shrink-0 text-success" />
              <span class="text-sm font-medium text-text">{item}</span>
            </li>
          ))}
        </ul>

        <a
          href="#contact"
          class="group mt-8 flex w-full items-center justify-center gap-2 rounded-md bg-primary py-4 text-base font-bold text-white transition-all hover:bg-primary-light hover:shadow-lg active:scale-[0.98]"
        >
          Solicita oferta
          <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
        </a>
      </div>
    </div>
  </div>
</section>
