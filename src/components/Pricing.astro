---
import { Check, ArrowRight } from "@lucide/astro";

const included = [
  "Aplicatie POS cu offline complet",
  "Panou admin cu dashboard AI",
  "Bon fiscal Datecs integrat",
  "Cantar Dibal integrat",
  "Multi-magazin din acelasi cont",
  "Update-uri OTA automate",
  "Import MicroERP inclus",
  "Suport tehnic prin email",
];
---

<section id="pricing" class="bg-white py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <!-- Left: Big bold statement -->
      <div>
        <h2 class="text-4xl font-black tracking-tight text-gray-900 sm:text-5xl">
          Simplu.<br />
          Transparent.<br />
          <span class="text-brand-600">Fara surprize.</span>
        </h2>
        <p class="mt-6 text-lg text-gray-500">
          Contacteaza-ne pentru o oferta personalizata. Fiecare magazin e diferit — pretul depinde de numarul de terminale si ce ai nevoie.
        </p>
        <div class="mt-8 rounded-2xl bg-warm-50 border-2 border-warm-100 p-6">
          <p class="text-2xl font-black text-gray-900">~600 lei economie</p>
          <p class="mt-1 text-sm text-gray-500">per terminal, fara licenta Windows</p>
        </div>
      </div>

      <!-- Right: What's included -->
      <div class="rounded-3xl border-2 border-gray-100 p-8 md:p-10">
        <h3 class="text-lg font-black text-gray-900">Include:</h3>
        <ul class="mt-6 space-y-4">
          {included.map((item) => (
            <li class="flex items-start gap-3">
              <Check class="mt-0.5 h-5 w-5 shrink-0 text-brand-600" />
              <span class="text-sm font-medium text-gray-700">{item}</span>
            </li>
          ))}
        </ul>

        <a
          href="#contact"
          class="group mt-8 flex w-full items-center justify-center gap-2 rounded-2xl bg-gray-900 py-4 text-base font-bold text-white transition-all hover:bg-gray-800 hover:scale-[1.01] active:scale-[0.99]"
        >
          Solicita oferta
          <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
        </a>
      </div>
    </div>
  </div>
</section>
